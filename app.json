{
  "expo": {
    "name": "Tower Defense",
    "slug": "tower-defense-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.subcontrollerllc.towerdefense",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.subcontrollerllc.towerdefense"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "towerdefense",
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    }
  }
}
